<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cvt="clr-namespace:Junevy.Controls.Converters"
    xmlns:local="clr-namespace:Junevy.Controls.Controls.Button">


    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Junevy.Controls;component/Themes/AppColors.xaml" />
        <ResourceDictionary Source="/Junevy.Controls.Resources;component/Font/IconFont.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <cvt:BoolToVisibilityConverter x:Key="BoolToVisibility" />


    <ControlTemplate x:Key="ExpanderControlTemplate" TargetType="{x:Type local:ToggleButton}">
        <Border x:Name="Host">
            <ContentControl
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Content="{TemplateBinding Content}"
                FontFamily="{TemplateBinding FontFamily}"
                FontSize="{TemplateBinding FontSize}"
                Foreground="{StaticResource AppColor}" />
        </Border>

        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseCaptured" Value="True">
                <Setter TargetName="Host" Property="Background" Value="{StaticResource IndicatorColor}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>



    <ControlTemplate x:Key="SwitchToggleButton_Rect" TargetType="{x:Type local:ToggleButton}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition MinWidth="40" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Width="{TemplateBinding Width}"
                Height="{TemplateBinding Height}"
                Padding="1"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="1">
                <Grid HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        x:Name="Left"
                        Grid.Column="0"
                        Background="{StaticResource AppColor}">
                        <ContentControl />
                    </Border>

                    <Border
                        x:Name="Right"
                        Grid.Column="1"
                        Background="Transparent" />
                </Grid>
            </Border>


            <Grid Grid.Column="1">
                <ContentControl
                    Margin="10,0,0,0"
                    Background="{TemplateBinding Background}"
                    Content="{TemplateBinding Content}"
                    FontFamily="{TemplateBinding FontFamily}"
                    FontSize="{TemplateBinding FontSize}"
                    Visibility="{TemplateBinding Content,
                                                 Converter={StaticResource BoolToVisibility}}" />
            </Grid>
        </Grid>

        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Left" Property="Background" Value="Transparent" />
                <Setter TargetName="Right" Property="Background" Value="{StaticResource AppColor}" />
            </Trigger>

            <Trigger Property="IsChecked" Value="False">
                <Setter TargetName="Left" Property="Background" Value="{StaticResource IndicatorColor}" />
                <Setter TargetName="Right" Property="Background" Value="Transparent" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>


    <ControlTemplate x:Key="SwitchToggleButton_Radius" TargetType="{x:Type local:ToggleButton}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition MinWidth="40" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="1"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="1"
                CornerRadius="{Binding RelativeSource={RelativeSource AncestorType=local:ToggleButton}, Path=(Border.CornerRadius)}">

                <Grid HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        x:Name="Left"
                        Grid.Column="0"
                        Background="{StaticResource AppColor}"
                        CornerRadius="{Binding RelativeSource={RelativeSource AncestorType=local:ToggleButton}, Path=(Border.CornerRadius)}">
                        <ContentControl />
                    </Border>

                    <Border
                        x:Name="Right"
                        Grid.Column="1"
                        Background="Transparent"
                        CornerRadius="{Binding RelativeSource={RelativeSource AncestorType=local:ToggleButton}, Path=(Border.CornerRadius)}" />
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <ContentControl
                    Margin="10,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="{TemplateBinding Background}"
                    Content="{TemplateBinding Content}"
                    FontFamily="{TemplateBinding FontFamily}"
                    FontSize="{TemplateBinding FontSize}"
                    Foreground="{TemplateBinding Foreground}"
                    Visibility="{TemplateBinding Content,
                                                 Converter={StaticResource BoolToVisibility}}" />
            </Grid>
        </Grid>

        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Left" Property="Background" Value="Transparent" />
                <Setter TargetName="Right" Property="Background" Value="{StaticResource AppColor}" />
            </Trigger>

            <Trigger Property="IsChecked" Value="False">
                <Setter TargetName="Left" Property="Background" Value="{StaticResource IndicatorColor}" />
                <Setter TargetName="Right" Property="Background" Value="Transparent" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>


    <Style x:Key="DefaultToggleButton" TargetType="{x:Type local:ToggleButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource AppColor}" />
        <Setter Property="Margin" Value="5,5,0,5" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template" Value="{StaticResource SwitchToggleButton_Radius}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Border.CornerRadius" Value="10" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource TextFillColor}" />
    </Style>




    <Style
        x:Key="ExpanderButton"
        BasedOn="{StaticResource DefaultToggleButton}"
        TargetType="{x:Type local:ToggleButton}">
        <Setter Property="FontFamily" Value="{StaticResource IconFont}" />
        <Setter Property="Content" Value="&#xe650;" />
        <Setter Property="Template" Value="{StaticResource ExpanderControlTemplate}" />
    </Style>


    <Style BasedOn="{StaticResource DefaultToggleButton}" TargetType="{x:Type local:ToggleButton}" />
</ResourceDictionary>