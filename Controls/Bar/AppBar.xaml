<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Junevy.Controls.Controls.Bar"
    xmlns:menu="clr-namespace:Junevy.Controls.Controls.Menu"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Junevy.Controls;component/Themes/AppColors.xaml" />
        <ResourceDictionary Source="/Junevy.Controls;component/Themes/IconFont.xaml" />
    </ResourceDictionary.MergedDictionaries>


    <ControlTemplate x:Key="DefaultAppBar" TargetType="{x:Type local:AppBar}">
        <Grid
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="{TemplateBinding Background}">

            <Grid.ColumnDefinitions>
                <ColumnDefinition MaxWidth="120" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition MaxWidth="135" />
            </Grid.ColumnDefinitions>

            <!--  icon  -->
            <Border Grid.Column="0">
                <ContentControl
                    Margin="8"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Content="{TemplateBinding Content}"
                    FontFamily="{StaticResource IconFont}"
                    FontSize="{TemplateBinding FontSize}"
                    Foreground="{StaticResource TextFillColor}" />
            </Border>


            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition MaxHeight="25" />
                    <RowDefinition MaxHeight="1" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  title  -->
                <Grid Grid.Row="0">
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="{TemplateBinding FontSize}"
                        Foreground="{StaticResource TextFillColor}"
                        Text="{TemplateBinding WindowTitle}" />
                </Grid>

                <!--  seperator  -->
                <Border
                    Grid.Row="1"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1" />

                <!--  tools bar  -->
                <Grid Grid.Row="2">
                    <menu:ToolBar
                        MaxHeight="35"
                        Margin="0,0,0,2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        ItemsSource="{TemplateBinding Items}"
                        Orientation="Horizontal" />
                </Grid>
            </Grid>

            <Grid Grid.Column="2">
                <StackPanel Orientation="Horizontal">
                    <Button
                        Width="45"
                        Content="△"
                        FontSize="30" />
                    <Button
                        Width="45"
                        Content="○"
                        FontSize="30" />
                    <Button
                        Width="45"
                        Content="×"
                        FontSize="30" />
                </StackPanel>
            </Grid>
        </Grid>
    </ControlTemplate>

    <Style TargetType="{x:Type local:AppBar}">
        <Setter Property="Height" Value="50" />
        <Setter Property="Background" Value="{StaticResource SubBackground}" />
        <Setter Property="Template" Value="{StaticResource DefaultAppBar}" />
    </Style>
</ResourceDictionary>