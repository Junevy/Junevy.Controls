<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="clr-namespace:Junevy.Controls.AttachedProperties"
    xmlns:atch="clr-namespace:Junevy.Controls.AttachedProperties"
    xmlns:cvt="clr-namespace:Junevy.Controls.Converters"
    xmlns:local="clr-namespace:Junevy.Controls.Controls.Menu">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Junevy.Controls.Resources;component/Font/IconFont.xaml" />
        <ResourceDictionary Source="/Junevy.Controls;component/Themes/AppColors.xaml" />
        <ResourceDictionary Source="/Junevy.Controls;component/Generic/Style/DefaultFocusStyle.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <cvt:BoolToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <!--  horizontal mode / normal style  -->
    <DataTemplate x:Key="DefaultSideMenuStyle" DataType="{x:Type local:MenuItem}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition MaxWidth="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  指示器  -->
            <Border
                Grid.Column="0"
                Height="{Binding FontSize}"
                Margin="0,0,5,0"
                Background="{StaticResource AppColor}"
                CornerRadius="2"
                Visibility="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <StackPanel Grid.Column="1" Orientation="{Binding Orientation}">
                <!--  icon  -->
                <ContentControl
                    Margin="5"
                    VerticalAlignment="Center"
                    Content="{Binding Icon}"
                    FontFamily="{Binding RelativeSource={RelativeSource AncestorType=local:SideMenu}, Path=(atc:Icon.FontFamily)}"
                    FontSize="{Binding RelativeSource={RelativeSource AncestorType=local:SideMenu}, Path=FontSize}"
                    Foreground="{Binding RelativeSource={RelativeSource AncestorType=local:SideMenu}, Path=Foreground}"
                    Visibility="{Binding Icon, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!--  title  -->
                <TextBlock
                    Margin="5"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    FontSize="{Binding FontSize}"
                    Foreground="{Binding RelativeSource={RelativeSource AncestorType=local:SideMenu}, Path=(TextElement.Foreground)}"
                    Text="{Binding Title}"
                    Visibility="{Binding Title, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
        </Grid>
    </DataTemplate>

    <!--  icon mode / vertical mode  -->
    <DataTemplate x:Key="IconMenuStyle" DataType="{x:Type local:MenuItem}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition MaxWidth="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  指示器  -->
            <Border
                Grid.Column="0"
                Height="{Binding FontSize}"
                Margin="0,0,5,0"
                Background="{StaticResource AppColor}"
                CornerRadius="2"
                Visibility="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />


            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <!--  icon  -->
                <ContentControl
                    Grid.Row="0"
                    Margin="0,5,5,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Content="{Binding Icon}"
                    FontFamily="{Binding RelativeSource={RelativeSource AncestorType=local:SideMenu}, Path=(atc:Icon.FontFamily)}"
                    FontSize="{Binding FontSize}"
                    Foreground="{Binding RelativeSource={RelativeSource AncestorType=local:SideMenu}, Path=Foreground}"
                    Visibility="{Binding Icon, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!--  title  -->
                <TextBlock
                    Grid.Row="1"
                    Margin="0,0,5,5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{Binding RelativeSource={RelativeSource AncestorType=local:SideMenu}, Path=Foreground}"
                    Text="{Binding Title}"
                    Visibility="{Binding Title, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
        </Grid>
    </DataTemplate>


    <!--  style  -->
    <Style x:Key="DefaultSideMenu" TargetType="{x:Type local:SideMenu}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="Width" Value="150" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource TextFillColor}" />
        <Setter Property="FontSize" Value="12" />

        <!--  SideMenu容器  -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:SideMenu}">
                    <ScrollViewer
                        Focusable="False"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Hidden">
                        <Border
                            Background="{StaticResource SubBackground}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1">
                            <ItemsPresenter />
                        </Border>
                    </ScrollViewer>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <!--  Items布局  -->
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel Orientation="{Binding RelativeSource={RelativeSource AncestorType=local:SideMenu}, Path=Orientation}" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>

        <!--  Items 容器样式  -->
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="2" />
                    <Setter Property="Background" Value="Transparent" />

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border
                                    x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="5">

                                    <ContentPresenter />

                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="{StaticResource IndicatorColor}" />
                                    </Trigger>

                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="{StaticResource IndicatorColor}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>



    <Style BasedOn="{StaticResource DefaultSideMenu}" TargetType="{x:Type local:SideMenu}">
        <Style.Triggers>
            <Trigger Property="DisplayMode" Value="Horizontal">
                <Setter Property="ItemTemplate" Value="{StaticResource DefaultSideMenuStyle}" />
            </Trigger>
            <Trigger Property="DisplayMode" Value="Vertical">
                <Setter Property="ItemTemplate" Value="{StaticResource IconMenuStyle}" />
                <Setter Property="Width" Value="60" />
            </Trigger>
        </Style.Triggers>
    </Style>


</ResourceDictionary>