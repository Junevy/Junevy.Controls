<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:attach="clr-namespace:Junevy.Controls.AttachedProperties"
    xmlns:bt="clr-namespace:Junevy.Controls.Controls.Button"
    xmlns:cvt="clr-namespace:Junevy.Controls.Converters"
    xmlns:local="clr-namespace:Junevy.Controls.Controls.Menu"
    xmlns:tb="clr-namespace:Junevy.Controls.Controls.Text">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Junevy.Controls;component/Themes/AppColors.xaml" />
        <ResourceDictionary Source="/Junevy.Controls.Resources;component/Font/IconFont.xaml" />
        <ResourceDictionary Source="/Junevy.Controls;component/Controls/Button/Button.xaml" />
        <ResourceDictionary Source="/Junevy.Controls;component/Generic/Style/DefaultFocusStyle.xaml" />
        <ResourceDictionary Source="/Junevy.Controls;component/Controls/Text/TextBox.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <cvt:BoolToVisibilityConverter x:Key="BoolToVisibility" />

    <!--  1. 先定义 TabItem 的样式（最重要！）  -->
    <Style x:Key="DefualtTabMenuItemStyle" TargetType="{x:Type local:TabMenuItem}">
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="MinWidth" Value="120" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{StaticResource SubBackground}" />
        <Setter Property="TextElement.FontSize" Value="12" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource DefaultControlFocusVisualStyle}" />

        <Setter Property="TextElement.Foreground" Value="{StaticResource TextFillColor}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:TabMenuItem}">
                    <Border
                        x:Name="border"
                        Margin="0,0,2,0"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1,1,1,0"
                        CornerRadius="3,3,0,0">

                        <!--<Border.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Edit Title" IsCheckable="False" />
                            </ContextMenu>
                        </Border.ContextMenu>-->

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!--  指示器  -->
                            <Border
                                Grid.Column="0"
                                Background="{StaticResource AppColor}"
                                CornerRadius="2"
                                Visibility="{TemplateBinding IsSelected,
                                                             Converter={StaticResource BoolToVisibility}}" />

                            <Grid Grid.Column="1">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>

                                <!--  icon  -->
                                <ContentControl
                                    Grid.Column="0"
                                    Margin="5"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding Icon}"
                                    Focusable="False"
                                    FontFamily="{Binding RelativeSource={RelativeSource AncestorType=local:TabMenu}, Path=(attach:Icon.FontFamily)}"
                                    FontSize="{TemplateBinding FontSize}"
                                    Foreground="{TemplateBinding Foreground}"
                                    Visibility="{TemplateBinding Icon,
                                                                 Converter={StaticResource BoolToVisibility}}" />

                                <!--  title  -->
                                <TextBox
                                    x:Name="PART_EditHeaderTextBox"
                                    Grid.Column="1"
                                    Margin="5,0,20,0"
                                    VerticalAlignment="Center"
                                    FontSize="{TemplateBinding FontSize}"
                                    Foreground="{TemplateBinding Foreground}"
                                    IsReadOnly="True"
                                    Template="{StaticResource NoBorderTextBoxTemplate_WPF}"
                                    Text="{TemplateBinding Header}"
                                    Visibility="{TemplateBinding Header,
                                                                 Converter={StaticResource BoolToVisibility}}" />

                                <bt:Button
                                    Grid.Column="2"
                                    Height="{TemplateBinding Height}"
                                    Margin="5,0,5,0"
                                    HorizontalAlignment="Right"
                                    Content="&#xe639;"
                                    FontFamily="{Binding RelativeSource={RelativeSource AncestorType=local:TabMenu}, Path=(attach:Icon.FontFamily)}"
                                    Foreground="{TemplateBinding Foreground}"
                                    Template="{StaticResource NoBorderButtonTemplate}"
                                    Visibility="{Binding RelativeSource={RelativeSource AncestorType=local:TabMenu}, Path=(attach:AttachFuc.IsClosable), Converter={StaticResource BoolToVisibility}}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource MainBackground}" />
                            <Setter TargetName="border" Property="TextElement.Foreground" Value="{StaticResource TextFillColor}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource MainBackground}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  2. TabControl 的完整样式  -->
    <Style TargetType="{x:Type local:TabMenu}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource DefaultControlFocusVisualStyle}" />
        <Setter Property="attach:AttachFuc.IsClosable" Value="True" />

        <Setter Property="ItemContainerStyle" Value="{StaticResource DefualtTabMenuItemStyle}" />

        <!--  标签头排列方式（可改成 WrapPanel 实现自动换行）  -->
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>

        <!--  标签页内容区模板（可选）  -->
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Border
                        Padding="20"
                        Background="{StaticResource MainBackground}"
                        CornerRadius="0,8,8,8">
                        <ContentPresenter Content="{Binding Content}" />
                    </Border>
                </DataTemplate>
            </Setter.Value>
        </Setter>

        <!--  最重要的：ControlTemplate 重写整体结构  -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:TabMenu}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  标签头  -->
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                            <ItemsPresenter />
                        </ScrollViewer>

                        <!--  内容  -->
                        <Border
                            Grid.Row="1"
                            Background="{StaticResource MainBackground}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0">
                            <ContentPresenter Margin="0" ContentSource="SelectedContent" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>