<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:attach="clr-namespace:Junevy.Controls.AttachedProperties"
    xmlns:bt="clr-namespace:Junevy.Controls.Controls.Button"
    xmlns:cvt="clr-namespace:Junevy.Controls.Converters"
    xmlns:local="clr-namespace:Junevy.Controls.Controls.Menu">


    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Junevy.Controls;component/Themes/AppColors.xaml" />
        <ResourceDictionary Source="/Junevy.Controls.Resources;component/Font/IconFont.xaml" />
        <ResourceDictionary Source="/Junevy.Controls;component/Controls/Button/Button.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <cvt:BoolToVisibilityConverter x:Key="BoolToVisibility" />


    <!--  <heade  -->

    <DataTemplate x:Key="DefaultTabMenuItemTemplate" DataType="{x:Type local:TabMenuItem}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition MaxWidth="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  指示器  -->
            <Border
                Grid.Column="0"
                Height="{Binding FontSize}"
                Margin="0,0,5,0"
                Background="{StaticResource AppColor}"
                CornerRadius="2"
                Visibility="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected, Converter={StaticResource BoolToVisibility}}" />

            <StackPanel Grid.Column="1" Orientation="{Binding Orientation}">
                <!--  icon  -->
                <ContentControl
                    Margin="5"
                    VerticalAlignment="Center"
                    Content="{Binding Icon}"
                    Focusable="False"
                    FontFamily="{Binding RelativeSource={RelativeSource AncestorType=local:TabMenu}, Path=(attach:Icon.FontFamily)}"
                    FontSize="{Binding RelativeSource={RelativeSource AncestorType=local:TabMenu}, Path=FontSize}"
                    Foreground="{Binding RelativeSource={RelativeSource AncestorType=local:TabMenu}, Path=Foreground}"
                    Visibility="{Binding Icon, Converter={StaticResource BoolToVisibility}}" />

                <!--  title  -->
                <TextBlock
                    Margin="5,0,20,0"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    FontSize="{Binding RelativeSource={RelativeSource AncestorType=local:TabMenu}, Path=FontSize}"
                    Foreground="{Binding RelativeSource={RelativeSource AncestorType=local:TabMenu}, Path=Foreground}"
                    Text="{Binding Header}"
                    Visibility="{Binding Header, Converter={StaticResource BoolToVisibility}}" />


                <bt:Button
                    Margin="5,0,5,0"
                    Content="&#xe639;"
                    FontSize="{Binding RelativeSource={RelativeSource AncestorType=local:TabMenu}, Path=FontSize}"
                    Foreground="{Binding RelativeSource={RelativeSource AncestorType=local:TabMenu}, Path=Foreground}"
                    Template="{StaticResource NoBorderButtonTemplate}"
                    Visibility="{Binding RelativeSource={RelativeSource AncestorType=bt:Button}, Path=(attach:AttachFuc.IsClosable)}" />
            </StackPanel>
        </Grid>
    </DataTemplate>


    <!--  1. 先定义 TabItem 的样式（最重要！）  -->
    <Style TargetType="{x:Type local:TabMenuItem}">
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{StaticResource SubBackground}" />
        <Setter Property="TextElement.FontSize" Value="12" />
        <Setter Property="SnapsToDevicePixels" Value="True" />

        <Setter Property="TextElement.Foreground" Value="{StaticResource TextFillColor}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:TabMenuItem}">
                    <Border
                        x:Name="border"
                        Margin="2,0,2,0"
                        Background="{TemplateBinding Background}"
                        CornerRadius="8,8,0,0">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            ContentSource="Header" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource SubBackground}" />
                            <Setter TargetName="border" Property="TextElement.Foreground" Value="{StaticResource TextFillColor}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource IndicatorColor}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  2. TabControl 的完整样式  -->
    <Style TargetType="{x:Type local:TabMenu}">
        <Setter Property="ItemContainerStyle" Value="{StaticResource DefualtTabMenuItemStyle}" />

        <!--  标签头排列方式（可改成 WrapPanel 实现自动换行）  -->
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>

        <Setter Property="ItemTemplate" Value="{StaticResource DefaultTabMenuItemTemplate}" />

        <!--  标签页内容区模板（可选）  -->
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Border
                        Padding="20"
                        Background="{StaticResource BorderColor}"
                        CornerRadius="0,8,8,8">
                        <ContentPresenter Content="{Binding Content}" />
                    </Border>
                </DataTemplate>
            </Setter.Value>
        </Setter>

        <!--  最重要的：ControlTemplate 重写整体结构  -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:TabMenu}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <!--  标签头区域  -->
                            <RowDefinition Height="*" />
                            <!--  内容区域  -->
                        </Grid.RowDefinitions>

                        <!--  标签头  -->
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                            <ItemsPresenter />
                        </ScrollViewer>

                        <!--  选中标签的内容  -->
                        <Border
                            Grid.Row="1"
                            Background="{StaticResource SubBackground}"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="0">
                            <ContentPresenter Margin="10" ContentSource="SelectedContent" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>