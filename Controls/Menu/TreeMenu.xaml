<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="clr-namespace:Junevy.Controls.AttachedProperties"
    xmlns:bt="clr-namespace:Junevy.Controls.Controls.Button"
    xmlns:cvt="clr-namespace:Junevy.Controls.Converters"
    xmlns:local="clr-namespace:Junevy.Controls.Controls.Menu">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Junevy.Controls;component/Themes/AppColors.xaml" />
        <ResourceDictionary Source="/Junevy.Controls;component/Controls/Button/ToggleButton.xaml" />
        <ResourceDictionary Source="/Junevy.Controls;component/Generic/Style/DefaultFocusStyle.xaml" />
    </ResourceDictionary.MergedDictionaries>


    <cvt:BoolToVisibilityConverter x:Key="BoolToVisibility" />


    <Style x:Key="DefaultTreeMenuTemplate" TargetType="TreeViewItem">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource DefaultControlFocusVisualStyle}" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeViewItem">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition MaxWidth="20" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <!--  展开按钮  -->
                            <bt:ToggleButton
                                x:Name="ExpanderButton"
                                Grid.Column="0"
                                Width="16"
                                Height="16"
                                ClickMode="Press"
                                IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                Style="{StaticResource ExpanderButton}" />
                            <Border
                                x:Name="Root"
                                Grid.Column="1"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5">
                                <ContentPresenter Content="{TemplateBinding Header}" ContentTemplate="{TemplateBinding HeaderTemplate}" />
                            </Border>
                        </Grid>

                        <!--<StackPanel Orientation="Horizontal" />-->
                        <ItemsPresenter x:Name="ItemHost" Margin="0,0,0,0" />
                    </StackPanel>

                    <ControlTemplate.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="ExpanderButton" Property="Visibility" Value="Hidden" />
                        </Trigger>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="ItemHost" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ItemHost" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                    <!--  没有子节点时隐藏按钮  -->
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <HierarchicalDataTemplate
        x:Key="DefaultTreeMenuItemStyle"
        DataType="{x:Type local:TreeMenuItem}"
        ItemsSource="{Binding Childrens}">

        <StackPanel x:Name="Root" Orientation="Horizontal">
            <!--  icon  -->
            <ContentControl
                Margin="5"
                VerticalAlignment="Center"
                Content="{Binding Icon}"
                FontFamily="{Binding RelativeSource={RelativeSource AncestorType=local:TreeMenu}, Path=(atc:Icon.FontFamily)}"
                FontSize="{Binding RelativeSource={RelativeSource AncestorType=local:TreeMenu}, Path=FontSize}"
                Foreground="{Binding RelativeSource={RelativeSource AncestorType=local:TreeMenu}, Path=Foreground}"
                Visibility="{Binding Icon, Converter={StaticResource BoolToVisibility}}" />
            <!--  title  -->
            <TextBlock
                Margin="5"
                VerticalAlignment="Center"
                Background="Transparent"
                FontSize="{Binding RelativeSource={RelativeSource AncestorType=local:TreeMenu}, Path=FontSize}"
                Foreground="{Binding RelativeSource={RelativeSource AncestorType=local:TreeMenu}, Path=Foreground}"
                Text="{Binding Title}"
                Visibility="{Binding Title, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>

        <HierarchicalDataTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{StaticResource IndicatorColor}" />
            </Trigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=IsSelected}" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{StaticResource IndicatorColor}" />
            </DataTrigger>
        </HierarchicalDataTemplate.Triggers>
    </HierarchicalDataTemplate>


    <Style x:Key="IconTreeMenuTemplate" TargetType="TreeViewItem">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="atc:ExpanderBehavior.Enable" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource DefaultControlFocusVisualStyle}" />
        <!--  <Setter Property="IsExpanded" Value="{Binding }"  -->

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeViewItem">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition MaxWidth="5" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>

                            <Border
                                x:Name="Indicator"
                                Grid.Column="0"
                                Background="{StaticResource AppColor}"
                                CornerRadius="1"
                                Visibility="Collapsed" />

                            <Border
                                x:Name="Root"
                                Grid.Column="1"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5">
                                <ContentPresenter Content="{TemplateBinding Header}" ContentTemplate="{TemplateBinding HeaderTemplate}" />
                            </Border>
                        </Grid>

                        <ItemsPresenter
                            x:Name="ItemHost"
                            Grid.Row="1"
                            Margin="0,0,0,0" />
                    </StackPanel>

                    <ControlTemplate.Triggers>
                        <Trigger Property="HasItems" Value="True">
                            <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="ItemHost" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ItemHost" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <HierarchicalDataTemplate
        x:Key="IconTreeMenuItemStyle"
        DataType="{x:Type local:TreeMenuItem}"
        ItemsSource="{Binding Childrens}">

        <Grid x:Name="Root" Margin="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  icon  -->
            <ContentControl
                Grid.Column="0"
                Margin="10,10,5,10"
                VerticalAlignment="Center"
                Content="{Binding Icon}"
                FontFamily="{Binding RelativeSource={RelativeSource AncestorType=local:TreeMenu}, Path=(atc:Icon.FontFamily)}"
                FontSize="24"
                Foreground="{Binding RelativeSource={RelativeSource AncestorType=local:TreeMenu}, Path=Foreground}"
                Visibility="{Binding Icon, Converter={StaticResource BoolToVisibility}}" />
            <!--  title  -->
            <TextBlock
                x:Name="title"
                Grid.Column="1"
                Margin="10"
                VerticalAlignment="Center"
                Background="Transparent"
                FontSize="{Binding FontSize}"
                Foreground="{Binding RelativeSource={RelativeSource AncestorType=local:TreeMenu}, Path=Foreground}"
                Text="{Binding Title}"
                Visibility="{Binding Title, Converter={StaticResource BoolToVisibility}}" />
        </Grid>
        <HierarchicalDataTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{StaticResource IndicatorColor}" />
            </Trigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=IsSelected}" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{StaticResource IndicatorColor}" />
            </DataTrigger>
        </HierarchicalDataTemplate.Triggers>
    </HierarchicalDataTemplate>


    <Style TargetType="{x:Type local:TreeMenu}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource DefaultControlFocusVisualStyle}" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="Foreground" Value="{StaticResource TextFillColor}" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="Width" Value="150" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="TextElement.FontSize" Value="12" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource TextFillColor}" />

        <!--  TreeMenu的容器，定义TreeMenu的外观样式  -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:TreeMenu}">
                    <ScrollViewer
                        Focusable="False"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Hidden">
                        <Border
                            Background="{StaticResource SubBackground}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1">
                            <ItemsPresenter />
                        </Border>
                    </ScrollViewer>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <!--  子元素如何排列  -->
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <!--<VirtualizingStackPanel HorizontalAlignment="Stretch" Orientation="{Binding RelativeSource={RelativeSource AncestorType=local:TreeMenu}, Path=Orientation}" />-->
                    <Grid />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>


        <Style.Triggers>
            <Trigger Property="DisplayMode" Value="Icon">
                <Setter Property="ItemTemplate" Value="{StaticResource IconTreeMenuItemStyle}" />
                <Setter Property="ItemContainerStyle" Value="{StaticResource IconTreeMenuTemplate}" />
                <Setter Property="TextElement.FontSize" Value="14" />
            </Trigger>

            <Trigger Property="DisplayMode" Value="Normal">
                <Setter Property="ItemTemplate" Value="{StaticResource DefaultTreeMenuItemStyle}" />
                <Setter Property="ItemContainerStyle" Value="{StaticResource DefaultTreeMenuTemplate}" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>