<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:bt="clr-namespace:Junevy.Controls.Controls.Button"
    xmlns:cvt="clr-namespace:Junevy.Controls.Converters"
    xmlns:local="clr-namespace:Junevy.Controls.Controls.Menu">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Junevy.Controls;component/Themes/AppColors.xaml" />
        <ResourceDictionary Source="/Junevy.Controls;component/Controls/Button/ToggleButton.xaml" />
    </ResourceDictionary.MergedDictionaries>


    <cvt:BoolToVisibilityConverter x:Key="BoolToVisibility" />

    <HierarchicalDataTemplate
        x:Key="DefaultTreeMenu"
        DataType="{x:Type local:MenuItem}"
        ItemsSource="{Binding Children}">

        <Grid x:Name="Root">
            <Grid.ColumnDefinitions>
                <ColumnDefinition MaxWidth="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  指示器  -->
            <Border
                Grid.Column="0"
                Height="{Binding FontSize}"
                Margin="0,0,5,0"
                Background="{StaticResource AppColor}"
                CornerRadius="2"
                Visibility="Collapsed" />

            <StackPanel Grid.Column="1" Orientation="{Binding Orientation}">
                <!--  icon  -->
                <ContentControl
                    Width="{Binding FontSize}"
                    Height="{Binding FontSize}"
                    Margin="5"
                    VerticalAlignment="Center"
                    Content="{Binding Icon}"
                    FontFamily="{StaticResource IconFont}"
                    FontSize="{Binding FontSize}"
                    Foreground="{StaticResource TextFillColor}"
                    Visibility="{Binding Icon, Converter={StaticResource BoolToVisibility}}" />

                <!--  title  -->
                <TextBlock
                    Margin="5"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    FontSize="{Binding FontSize}"
                    Foreground="{StaticResource TextFillColor}"
                    Text="{Binding Title}"
                    Visibility="{Binding Title, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>
        </Grid>

        <HierarchicalDataTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{StaticResource IndicatorColor}" />
            </Trigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=IsSelected}" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{StaticResource IndicatorColor}" />
            </DataTrigger>
        </HierarchicalDataTemplate.Triggers>
    </HierarchicalDataTemplate>

    <Style TargetType="{x:Type local:TreeMenu}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="Width" Value="150" />
        <Setter Property="FontSize" Value="12" />

        <!--  TreeMenu的容器，定义TreeMenu的外观样式  -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:TreeMenu}">
                    <ScrollViewer
                        Focusable="False"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Hidden">
                        <Border
                            Background="{StaticResource SubBackground}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1">
                            <ItemsPresenter />
                        </Border>
                    </ScrollViewer>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <!--  子元素如何排列  -->
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel Orientation="{Binding RelativeSource={RelativeSource AncestorType=local:TreeMenu}, Path=Orientation}" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>


        <!--  每个 tree view item的样式  -->
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="TreeViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="2" />
                    <Setter Property="Background" Value="Transparent" />

                    <!--<EventSetter Event="MouseDoubleClick" Handler="OnItemDoubleClick" />-->

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TreeViewItem">

                                <StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <!--  展开按钮  -->
                                        <bt:ToggleButton
                                            x:Name="ItemsHost"
                                            Width="16"
                                            Height="16"
                                            ClickMode="Press"
                                            IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                            Style="{StaticResource ExpanderButton}" />
                                        <Border
                                            x:Name="Root"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="5">
                                            <ContentPresenter Content="{TemplateBinding Header}" ContentTemplate="{TemplateBinding HeaderTemplate}" />
                                        </Border>
                                    </StackPanel>
                                    <ItemsPresenter Margin="10,0,0,0" />
                                </StackPanel>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="HasItems" Value="False">
                                        <Setter TargetName="ItemsHost" Property="Visibility" Value="Hidden" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                                <!--  没有子节点时隐藏按钮  -->
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>

                </Style>
            </Setter.Value>
        </Setter>

        <Setter Property="ItemTemplate" Value="{StaticResource DefaultTreeMenu}" />
    </Style>
</ResourceDictionary>